# Database
DATABASE_URL="postgresql://csuite:csuite_dev@localhost:5432/csuite?schema=public"

# NextAuth v5 — AUTH_SECRET must be a random 32+ char string in production
AUTH_SECRET="your-random-32-char-secret-here-change-me"
AUTH_URL="http://localhost:3000"

# Demo mode (leave unset in production!)
# DEMO_MODE=true             wipes + reseeds demo data on every server boot
# NEXT_PUBLIC_DEMO_MODE=true shows the demo user switcher in the header (build-time)
DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"

# Production bootstrap — on a clean database (no staff users), creates the
# Central Creative org + this staff admin so someone can log in.
# Remove BOOTSTRAP_ADMIN_PASSWORD after the first successful boot.
# BOOTSTRAP_ADMIN_EMAIL="you@centralcreative.co"
# BOOTSTRAP_ADMIN_PASSWORD=""

# Transactional email (Resend — https://resend.com). When unset, emails are
# logged to the server console instead of sent.
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Central Creative <hello@yourdomain.com>"  # domain must be verified in Resend

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# File storage — S3-compatible (Cloudflare R2). When unset, files are stored
# on local disk in ./.uploads (dev only — not durable in production).
# S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_BUCKET="csuite-uploads"
# S3_REGION="auto"
# CDN_URL=""  # optional public bucket/CDN base URL; default serves via /api/files/serve
